                                </condition>
                                <echo message="git.properties exists? ${git.props.exists}" />
                                <sequential>
                                    <mkdir dir="${project.build.outputDirectory}" />
                                    <echo file="${project.build.outputDirectory}/git.properties" append="false">#
			fallback git.properties
